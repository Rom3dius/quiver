# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Bot command prefix (default: !)
BOT_COMMAND_PREFIX=!

# Discord role name for admin commands (default: C2 Operator)
ADMIN_ROLE_NAME=C2 Operator

# Database path (default: quiver.db in project root)
DATABASE_PATH=quiver.db

# Flask web dashboard
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Flask secret key for session signing and CSRF tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random key is generated on each startup (sessions won't persist).
FLASK_SECRET_KEY=

# File upload storage directory (default: uploads/)
UPLOADS_PATH=uploads
